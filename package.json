{
  "name": "access-matrix",
  "version": "0.1.0",
  "description": "A flexible and extensible access control library for Node.js applications, currently supporting SQLite with a clean, type-safe API. Designed to be easily extensible for additional database backends in the future.",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "example": "tsx examples/basic-usage.ts",
    "example:postgres": "tsx examples/postgres-usage.ts",
    "example:neon": "tsx examples/postgres-usage.ts neon",
    "example:autoload": "tsx examples/auto-loading-demo.ts",
    "lint": "eslint . --ext .ts",
    "test": "npx vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "access-control",
    "rbac",
    "pbac",
    "authorization",
    "permissions",
    "sqlite",
    "postgresql",
    "auto-loading",
    "routes",
    "typescript",
    "nodejs"
  ],
  "author": "Vineettt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vineettt/access-matrix.git"
  },
  "homepage": "https://github.com/Vineettt/access-matrix#readme",
  "bugs": {
    "url": "https://github.com/Vineettt/access-matrix/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Vineettt"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "c8": "^8.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
